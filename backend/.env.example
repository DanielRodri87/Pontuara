APP_NAME=Pontuara API
APP_VERSION=0.1.0

# URL do seu projeto Supabase, por exemplo:
# https://seu-projeto.supabase.co
SUPABASE_URL=

# Chave anon ou service_role do projeto.
SUPABASE_KEY=

SUPABASE_SCHEMA=public
SUPABASE_TIMEOUT=15

# Altere apenas se os nomes das tabelas no Supabase forem diferentes.
SUPABASE_USUARIOS_TABLE=usuarios
SUPABASE_TRABALHOS_TABLE=trabalhos
SUPABASE_EXPEDIENTES_TABLE=expedientes
